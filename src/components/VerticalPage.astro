---
import Base from '../layouts/Base.astro'
import Footer from '../components/Footer.astro'

interface Bullet {
  title: string
  text: string
}

interface Props {
  vertical: string
  headline: string
  subheadline: string
  bullets: Bullet[]
  cta: string
  seoTitle: string
  ctaButton?: string
  ctaHref?: string
  ctaForm?: boolean
  footerText?: string
}

const { vertical, headline, subheadline, bullets, cta, seoTitle, ctaButton, ctaHref, ctaForm, footerText } = Astro.props
---

<Base title={seoTitle}>
  <header class="w-full border-b border-warm-gray-200">
    <nav class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
      <a href="/">
        <img src="/extol-logo.svg" alt="Extol" class="h-6" />
      </a>
      <a
        href="https://brij.extol.work"
        class="text-sm font-medium px-4 py-2 bg-terracotta-500 text-cream rounded-lg hover:bg-terracotta-600 transition-colors"
      >
        Start free with brij &rarr;
      </a>
    </nav>
  </header>

  <main>
    <section class="max-w-3xl mx-auto px-6 pt-24 pb-16">
      <h1 class="font-serif text-4xl sm:text-5xl font-600 leading-tight text-bark-900">
        {headline}
      </h1>
      <p class="mt-6 text-lg text-warm-gray-500 leading-relaxed">
        {subheadline}
      </p>
    </section>

    <section class="max-w-3xl mx-auto px-6 pb-20">
      <div class="space-y-8">
        {bullets.map((bullet) => (
          <div>
            <p class="font-semibold text-bark-900">{bullet.title}</p>
            <p class="mt-2 text-warm-gray-500 leading-relaxed">{bullet.text}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-bark-900 py-20">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="font-serif text-3xl sm:text-4xl font-500 text-cream">
          {cta}
        </h2>
        <div class="mt-8">
          {ctaForm ? (
            <div class="max-w-md mx-auto" id="waitlist-form">
              <p class="text-sm text-warm-gray-400 mb-4">Enter your email. We'll reach out when Extol is ready for nonprofits.</p>
              <div class="flex gap-3">
                <input
                  type="email"
                  id="waitlist-email"
                  required
                  placeholder="you@nonprofit.org"
                  class="flex-1 px-4 py-3 rounded-lg bg-bark-800 text-cream border border-warm-gray-500 placeholder:text-warm-gray-500 focus:outline-none focus:border-terracotta-400 text-base"
                />
                <button
                  type="button"
                  id="waitlist-btn"
                  class="px-6 py-3 text-base font-medium bg-terracotta-500 text-cream rounded-lg hover:bg-terracotta-400 transition-colors whitespace-nowrap"
                >
                  Join waitlist
                </button>
              </div>
              <p id="waitlist-thanks" class="hidden text-sm text-terracotta-400 mt-4">Thanks! We'll be in touch.</p>
            </div>
            <script>
              document.getElementById('waitlist-btn')?.addEventListener('click', () => {
                const input = document.getElementById('waitlist-email') as HTMLInputElement
                const email = input?.value?.trim()
                if (!email || !input?.checkValidity()) { input?.reportValidity(); return }
                window.location.href = `mailto:info@extol.work?subject=${encodeURIComponent('Nonprofit waitlist')}&body=${encodeURIComponent(`Waitlist signup: ${email}`)}`
                document.getElementById('waitlist-thanks')?.classList.remove('hidden')
                input.value = ''
              })
            </script>
          ) : (
            <a
              href={ctaHref || "https://brij.extol.work"}
              class="inline-flex items-center justify-center px-8 py-3 text-base font-medium bg-terracotta-500 text-cream rounded-lg hover:bg-terracotta-400 transition-colors"
            >
              {ctaButton || 'Start free with brij →'}
            </a>
          )}
        </div>
        <p class="mt-8 text-sm text-warm-gray-500">
          {footerText || 'brij is free forever. Governance tools available when your group is ready.'}
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>
