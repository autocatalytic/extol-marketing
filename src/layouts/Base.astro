---
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Extol — Transparent agreements for bands, nonprofits, and open source projects',
  description = 'Your community already has agreements, contributions, and economics. Extol makes them visible to everyone.',
} = Astro.props
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://extol.work" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-bark-800 font-sans antialiased">
    <slot />
  </body>
</html>
