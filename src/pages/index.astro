---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Billboard from '../components/Billboard.astro'
import Ledger from '../components/Ledger.astro'
import ProposalBanner from '../components/ProposalBanner.astro'
---

<Base title="Extol — The ledger for everything people build together">
  <Header />

  <main>
    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-6 pt-24 pb-20">
      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-600 leading-tight text-bark-900 max-w-4xl">
        The most valuable work happens together. <br />
        <span class="text-terracotta-500">The economy just hasn't caught up.</span>
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-warm-gray-500 max-w-2xl leading-relaxed">
        People create enormous value together — splitting revenue, running budgets, showing up week after week. But the tools that track value were built for companies, not communities. Extol is the ledger for everything people build together.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a
          href="#waitlist"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium bg-terracotta-500 text-cream rounded-lg hover:bg-terracotta-600 transition-colors"
        >
          Join the waitlist
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-bark-800 border border-warm-gray-200 rounded-lg hover:bg-warm-gray-100 transition-colors"
        >
          How it works
        </a>
      </div>
    </section>

    <!-- Section 1: Every contribution deserves to be remembered -->
    <section id="for-whom" class="py-16">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="font-serif text-3xl sm:text-4xl font-500 text-bark-900">
          Every contribution deserves to be remembered.
        </h2>
      </div>
      <div class="mt-10 max-w-5xl mx-auto px-6">
        <div class="flex gap-4 overflow-x-auto scroll-snap-x-mandatory pb-4 -mx-6 px-6" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">
          <!-- Doing things together — invitation card -->
          <a href="https://app.extol.work" class="flex-shrink-0 w-[280px] rounded-xl p-6 bg-violet-50 border-l-4 border-violet-400 scroll-snap-start hover:border-violet-600 transition-colors">
            <p class="font-semibold text-violet-500">Doing things together</p>
            <p class="mt-2 text-sm text-warm-gray-500 leading-relaxed">
              Cleanups, practices, jam sessions, Saturday hikes. It all counts.
            </p>
          </a>
          <!-- Bands -->
          <a href="/bands" class="flex-shrink-0 w-[280px] rounded-xl p-6 bg-white border border-warm-gray-200 scroll-snap-start hover:border-terracotta-400 transition-colors">
            <p class="font-semibold text-bark-900">Bands &amp; Creatives</p>
            <p class="mt-2 text-sm text-warm-gray-500 leading-relaxed">
              Four people created something valuable. Extol makes sure all four are accounted for.
            </p>
          </a>
          <!-- Nonprofits -->
          <a href="/nonprofits" class="flex-shrink-0 w-[280px] rounded-xl p-6 bg-white border border-warm-gray-200 scroll-snap-start hover:border-terracotta-400 transition-colors">
            <p class="font-semibold text-bark-900">Nonprofits</p>
            <p class="mt-2 text-sm text-warm-gray-500 leading-relaxed">
              Volunteers, donors, board members — all creating value for their communities. Extol gives them a shared record.
            </p>
          </a>
          <!-- Sports Clubs -->
          <a href="/clubs" class="flex-shrink-0 w-[280px] rounded-xl p-6 bg-white border border-warm-gray-200 scroll-snap-start hover:border-terracotta-400 transition-colors">
            <p class="font-semibold text-bark-900">Sports Clubs</p>
            <p class="mt-2 text-sm text-warm-gray-500 leading-relaxed">
              Parents and coaches create enormous community value. Extol shows where it goes.
            </p>
          </a>
          <!-- Open Source -->
          <a href="/oss" class="flex-shrink-0 w-[280px] rounded-xl p-6 bg-white border border-warm-gray-200 scroll-snap-start hover:border-terracotta-400 transition-colors">
            <p class="font-semibold text-bark-900">Open Source</p>
            <p class="mt-2 text-sm text-warm-gray-500 leading-relaxed">
              Thousands of people built something valuable. Extol tracks what a commit log can't.
            </p>
          </a>
        </div>
      </div>
    </section>

    <!-- Section 2: Here's what it looks like -->
    <section id="how-it-works" class="bg-warm-gray-100 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="font-serif text-3xl sm:text-4xl font-500 text-bark-900">
          Here's what it looks like. <span class="text-red-700 text-2xl sm:text-3xl">Coming soon</span>
        </h2>

        <!-- The Agreement -->
        <div class="mt-12 grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <h3 class="text-xl font-semibold text-bark-900">The Agreement</h3>
            <p class="mt-3 text-warm-gray-500 leading-relaxed">
              Proportional blocks show who gets what — visible to every member, decided together.
            </p>
          </div>
          <div>
            <Billboard variant="split" />
          </div>
        </div>

        <!-- The Ledger -->
        <div class="mt-16 grid lg:grid-cols-2 gap-12 items-start">
          <div class="lg:order-2">
            <h3 class="text-xl font-semibold text-bark-900">The Ledger</h3>
            <p class="mt-3 text-warm-gray-500 leading-relaxed">
              Enter one number. Everyone sees their share.
            </p>
          </div>
          <div class="lg:order-1">
            <Ledger />
          </div>
        </div>

        <!-- Decisions -->
        <div class="mt-16 grid lg:grid-cols-2 gap-12 items-start">
          <div>
            <h3 class="text-xl font-semibold text-bark-900">Decisions Without Meetings</h3>
            <p class="mt-3 text-warm-gray-500 leading-relaxed">
              Proposals pass automatically unless someone raises a concern. No voting, no quorum, no scheduling a call.
            </p>
          </div>
          <div>
            <ProposalBanner />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Sound familiar? -->
    <section class="py-20">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="font-serif text-3xl sm:text-4xl font-500 text-bark-900">
          Sound familiar?
        </h2>
        <p class="mt-6 text-lg font-medium text-bark-900">
          Your group already does this. Just harder than it should be.
        </p>
        <p class="mt-4 text-warm-gray-500 leading-relaxed">
          Someone tracks the money in a spreadsheet. Someone else texts the numbers. Everyone hopes the math is right and nobody disputes it. When someone leaves or a new member joins, the split conversation happens over text — or doesn't happen at all.
        </p>
        <p class="mt-4 text-warm-gray-500 leading-relaxed">
          Extol replaces the spreadsheet, the awkward conversation, and the hope. One agreement, visible to everyone, changeable only when the group decides.
        </p>
      </div>
    </section>

    <!-- Waitlist -->
    <section id="waitlist" class="bg-bark-900 py-20">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="font-serif text-3xl sm:text-4xl font-500 text-cream">
          Your group already does the hard part. <br />
          Extol makes sure none of it gets lost.
        </h2>
        <p class="mt-4 text-amber-200 max-w-xl mx-auto">
          We make the invisible work that holds communities together visible, so the people doing it actually get credit. Join the waitlist to be first in.
        </p>
        <div class="mt-8 flex justify-center">
          <form id="waitlist-form" class="flex flex-col sm:flex-row gap-3 w-full max-w-md">
            <input
              id="waitlist-email"
              type="email"
              placeholder="you@community.org"
              required
              class="flex-1 px-4 py-3 rounded-lg bg-bark-800 text-cream placeholder-warm-gray-500 border border-bark-700 focus:outline-none focus:border-terracotta-400"
            />
            <button
              type="submit"
              id="waitlist-btn"
              class="px-6 py-3 font-medium bg-terracotta-500 text-cream rounded-lg hover:bg-terracotta-400 transition-colors"
            >
              Join waitlist
            </button>
          </form>
          <p id="waitlist-success" class="hidden mt-4 text-amber-200">
            You're on the list. We'll be in touch.
          </p>
          <p id="waitlist-error" class="hidden mt-4 text-terracotta-400">
            Something went wrong. Please try again.
          </p>
        </div>
      </div>
    </section>

    <script>
      const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbzq9UxvGGIyKExjc6UJjh3jqRObDTVDnCIFlTAT6vSMKY_gi9ivaqOj9G4L9mvUyLGN/exec';

      const params = new URLSearchParams(window.location.search);

      document.getElementById('waitlist-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = (document.getElementById('waitlist-email') as HTMLInputElement).value;
        const btn = document.getElementById('waitlist-btn') as HTMLButtonElement;
        const form = document.getElementById('waitlist-form') as HTMLFormElement;
        const success = document.getElementById('waitlist-success')!;
        const error = document.getElementById('waitlist-error')!;

        const payload = {
          email,
          slug: '/',
          utm_source: params.get('utm_source') || '',
          utm_medium: params.get('utm_medium') || '',
          utm_campaign: params.get('utm_campaign') || '',
          utm_content: params.get('utm_content') || '',
          ref: params.get('ref') || '',
          timestamp: new Date().toISOString(),
        };

        btn.textContent = 'Sending...';
        btn.disabled = true;
        error.classList.add('hidden');

        try {
          await fetch(APPS_SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          form.classList.add('hidden');
          success.classList.remove('hidden');

          if (typeof posthog !== 'undefined') {
            posthog.capture('waitlist_signup', {
              slug: '/',
              utm_source: payload.utm_source,
              utm_campaign: payload.utm_campaign,
            });
          }
        } catch {
          error.classList.remove('hidden');
          btn.textContent = 'Join waitlist';
          btn.disabled = false;
        }
      });
    </script>
  </main>

  <Footer />
</Base>
