    color: var(--color-bark-900, #2C1810);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-bark-900, #2C1810);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose p, .prose li {
    color: var(--color-warm-gray-500, #6B5E54);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .prose ul {
    padding-left: 1.25rem;
    list-style-type: disc;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose a {
    color: var(--color-terracotta-500, #C75B3F);
    text-decoration: underline;
